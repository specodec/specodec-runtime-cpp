export inline specodec::SpecCodec<DeepNest3> DeepNest3Codec = {
    .encode = [](specodec::SpecWriter& w, const DeepNest3& obj) { write_deep_nest3(w, obj); },
    .decode = [](specodec::SpecReader& r) -> DeepNest3 {
        std::string fld_title = "";
        Point3 fld_point = {};
        Range32 fld_value_range = {};
        Money fld_money = {};
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "title") { fld_title = r.readString(); }
            else if (field_name == "point") { fld_point = Point3Codec.decode(r); }
            else if (field_name == "value_range") { fld_value_range = Range32Codec.decode(r); }
            else if (field_name == "money") { fld_money = MoneyCodec.decode(r); }
            else { r.skip(); }
        }
        r.endObject();
        return DeepNest3{fld_title, fld_point, fld_value_range, fld_money};
    }
};

export struct DeepNest4 {
    std::vector<Coord> coords;
    Inner nested;
    std::string tag;
};

export inline void write_deep_nest4(specodec::SpecWriter& w, const DeepNest4& obj) {
    w.beginObject(3);
    w.writeField("coords"); 
        w.beginArray(obj.coords.size());
        for (const auto& elem : obj.coords) { w.nextElement(); write_coord(w, elem); }
        w.endArray();
    w.writeField("nested"); write_inner(w, obj.nested);;
    w.writeField("tag"); w.writeString(obj.tag);;
    w.endObject();
}

export inline specodec::SpecCodec<DeepNest4> DeepNest4Codec = {
    .encode = [](specodec::SpecWriter& w, const DeepNest4& obj) { write_deep_nest4(w, obj); },
    .decode = [](specodec::SpecReader& r) -> DeepNest4 {
        std::vector<Coord> fld_coords = {};
        Inner fld_nested = {};
        std::string fld_tag = "";
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "coords") { fld_coords = [&]() {
    std::vector<Coord> result;
    r.beginArray();
    while (r.hasNextElement()) { result.push_back(CoordCodec.decode(r)); }
    r.endArray();
    return result;
}(); }
            else if (field_name == "nested") { fld_nested = InnerCodec.decode(r); }
            else if (field_name == "tag") { fld_tag = r.readString(); }
            else { r.skip(); }
        }
        r.endObject();
        return DeepNest4{fld_coords, fld_nested, fld_tag};
    }
};

