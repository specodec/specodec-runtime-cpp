export struct DeepNest6 {
    std::vector<IdVal> items;
    std::optional<Addr> addr;
    Coord coord;
};

export inline void write_deep_nest6(specodec::SpecWriter& w, const DeepNest6& obj) {
    int field_count = 2;
    if (obj.addr.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("items"); 
        w.beginArray(obj.items.size());
        for (const auto& elem : obj.items) { w.nextElement(); write_id_val(w, elem); }
        w.endArray();
    if (obj.addr.has_value()) { w.writeField("addr"); write_addr(w, obj.addr.value());; }
    w.writeField("coord"); write_coord(w, obj.coord);;
    w.endObject();
}

export inline specodec::SpecCodec<DeepNest6> DeepNest6Codec = {
    .encode = [](specodec::SpecWriter& w, const DeepNest6& obj) { write_deep_nest6(w, obj); },
    .decode = [](specodec::SpecReader& r) -> DeepNest6 {
        std::vector<IdVal> fld_items = {};
        std::optional<Addr> fld_addr;
        Coord fld_coord = {};
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "items") { fld_items = [&]() {
    std::vector<IdVal> result;
    r.beginArray();
    while (r.hasNextElement()) { result.push_back(IdValCodec.decode(r)); }
    r.endArray();
    return result;
}(); }
            else if (field_name == "addr") { fld_addr = std::optional<Addr>{(r.isNull() ? (r.readNull(), std::optional<Addr>{std::nullopt}) : std::optional<Addr>{AddrCodec.decode(r)})}; }
            else if (field_name == "coord") { fld_coord = CoordCodec.decode(r); }
            else { r.skip(); }
        }
        r.endObject();
        return DeepNest6{fld_items, fld_addr, fld_coord};
    }
};

export struct DeepNest7 {
    Addr a;
    Addr b;
    Addr c;
};

export inline void write_deep_nest7(specodec::SpecWriter& w, const DeepNest7& obj) {
    w.beginObject(3);
    w.writeField("a"); write_addr(w, obj.a);;
    w.writeField("b"); write_addr(w, obj.b);;
    w.writeField("c"); write_addr(w, obj.c);;
    w.endObject();
}

export inline specodec::SpecCodec<DeepNest7> DeepNest7Codec = {
    .encode = [](specodec::SpecWriter& w, const DeepNest7& obj) { write_deep_nest7(w, obj); },
    .decode = [](specodec::SpecReader& r) -> DeepNest7 {
        Addr fld_a = {};
        Addr fld_b = {};
        Addr fld_c = {};
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "a") { fld_a = AddrCodec.decode(r); }
            else if (field_name == "b") { fld_b = AddrCodec.decode(r); }
            else if (field_name == "c") { fld_c = AddrCodec.decode(r); }
            else { r.skip(); }
        }
        r.endObject();
        return DeepNest7{fld_a, fld_b, fld_c};
    }
};

export struct TimestampEntry {
    std::int64_t ts;
    std::string event;
    std::optional<std::vector<std::uint8_t>> payload;
};

export inline void write_timestamp_entry(specodec::SpecWriter& w, const TimestampEntry& obj) {
    int field_count = 2;
    if (obj.payload.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("ts"); w.writeInt64(obj.ts);;
    w.writeField("event"); w.writeString(obj.event);;
    if (obj.payload.has_value()) { w.writeField("payload"); w.writeBytes(obj.payload.value());; }
    w.endObject();
}

export inline specodec::SpecCodec<TimestampEntry> TimestampEntryCodec = {
    .encode = [](specodec::SpecWriter& w, const TimestampEntry& obj) { write_timestamp_entry(w, obj); },
    .decode = [](specodec::SpecReader& r) -> TimestampEntry {
        std::int64_t fld_ts = 0LL;
        std::string fld_event = "";
        std::optional<std::vector<std::uint8_t>> fld_payload;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "ts") { fld_ts = r.readInt64(); }
            else if (field_name == "event") { fld_event = r.readString(); }
            else if (field_name == "payload") { fld_payload = std::optional<std::vector<std::uint8_t>>{r.readBytes()}; }
            else { r.skip(); }
        }
        r.endObject();
        return TimestampEntry{fld_ts, fld_event, fld_payload};
    }
};

export struct ConfigEntry {
    std::string key;
    std::optional<std::int32_t> intValue;
    std::optional<std::string> strValue;
    std::optional<bool> boolValue;
    std::optional<double> floatValue;
};

export inline void write_config_entry(specodec::SpecWriter& w, const ConfigEntry& obj) {
    int field_count = 1;
    if (obj.intValue.has_value()) field_count++;
    if (obj.strValue.has_value()) field_count++;
    if (obj.boolValue.has_value()) field_count++;
    if (obj.floatValue.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("key"); w.writeString(obj.key);;
    if (obj.intValue.has_value()) { w.writeField("intValue"); w.writeInt32(obj.intValue.value());; }
    if (obj.strValue.has_value()) { w.writeField("strValue"); w.writeString(obj.strValue.value());; }
    if (obj.boolValue.has_value()) { w.writeField("boolValue"); w.writeBool(obj.boolValue.value());; }
    if (obj.floatValue.has_value()) { w.writeField("floatValue"); w.writeFloat64(obj.floatValue.value());; }
    w.endObject();
}

export inline specodec::SpecCodec<ConfigEntry> ConfigEntryCodec = {
    .encode = [](specodec::SpecWriter& w, const ConfigEntry& obj) { write_config_entry(w, obj); },
    .decode = [](specodec::SpecReader& r) -> ConfigEntry {
        std::string fld_key = "";
        std::optional<std::int32_t> fld_intValue;
        std::optional<std::string> fld_strValue;
        std::optional<bool> fld_boolValue;
        std::optional<double> fld_floatValue;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "key") { fld_key = r.readString(); }
            else if (field_name == "intValue") { fld_intValue = std::optional<std::int32_t>{r.readInt32()}; }
            else if (field_name == "strValue") { fld_strValue = std::optional<std::string>{r.readString()}; }
            else if (field_name == "boolValue") { fld_boolValue = std::optional<bool>{r.readBool()}; }
            else if (field_name == "floatValue") { fld_floatValue = std::optional<double>{r.readFloat64()}; }
            else { r.skip(); }
        }
        r.endObject();
        return ConfigEntry{fld_key, fld_intValue, fld_strValue, fld_boolValue, fld_floatValue};
    }
};

} // namespace all_types_extra