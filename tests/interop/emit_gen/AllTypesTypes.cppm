export struct OptCombo1 {
    std::string req;
    std::optional<std::int32_t> opt_a;
};

export inline void _writeOptCombo1(SpecWriter& w, const OptCombo1& obj) {
    int _n = 1;
    if (obj.opt_a.has_value()) _n++;
    w.beginObject(_n);
    w.writeField("req"); w.writeString(obj.req);;
    if (obj.opt_a.has_value()) { w.writeField("opt_a"); w.writeInt32(obj.opt_a.value());; }
    w.endObject();
}

export inline SpecCodec<OptCombo1> OptCombo1Codec = {
    .encode = [](SpecWriter& w, const OptCombo1& obj) { _writeOptCombo1(w, obj); },
    .decode = [](SpecReader& r) -> OptCombo1 {
        std::string _req = "";
        std::optional<std::int32_t> _opt_a;
        r.beginObject();
        while (r.hasNextField()) {
            auto _fn = r.readFieldName();
            if (_fn == "req") { _req = r.readString(); }
            else if (_fn == "opt_a") { _opt_a = std::optional<std::int32_t>{r.readInt32()}; }
            else { r.skip(); }
        }
        r.endObject();
        return OptCombo1{_req, _opt_a};
    }
};

