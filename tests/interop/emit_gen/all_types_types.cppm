export struct EdgeNullable {
    std::optional<std::string> a;
    std::optional<std::int32_t> b;
    std::optional<Inner> c;
    std::optional<std::vector<std::string>> d;
};

export inline void write_edge_nullable(specodec::SpecWriter& w, const EdgeNullable& obj) {
    int field_count = 0;
    if (obj.a.has_value()) field_count++;
    if (obj.b.has_value()) field_count++;
    if (obj.c.has_value()) field_count++;
    if (obj.d.has_value()) field_count++;
    w.beginObject(field_count);
    if (obj.a.has_value()) { w.writeField("a"); w.writeString(obj.a.value());; }
    if (obj.b.has_value()) { w.writeField("b"); w.writeInt32(obj.b.value());; }
    if (obj.c.has_value()) { w.writeField("c"); write_inner(w, obj.c.value());; }
    if (obj.d.has_value()) { w.writeField("d"); 
        w.beginArray(obj.d.value().size());
        for (const auto& elem : obj.d.value()) { w.nextElement(); w.writeString(elem); }
        w.endArray(); }
    w.endObject();
}

