            else if (_fn == "strValue") { _strValue = std::optional<std::string>{r.readString()}; }
            else if (_fn == "boolValue") { _boolValue = std::optional<bool>{r.readBool()}; }
            else if (_fn == "floatValue") { _floatValue = std::optional<double>{r.readFloat64()}; }
            else { r.skip(); }
        }
        r.endObject();
        return ConfigEntry{_key, _intValue, _strValue, _boolValue, _floatValue};
