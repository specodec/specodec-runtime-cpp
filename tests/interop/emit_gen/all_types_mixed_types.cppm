export struct Mix15 {
    Addr src_addr_;
    Addr dst_addr_;
    double distance_;
    double duration_;
};

export inline void write_mix15(specodec::SpecWriter& w, const Mix15& obj) {
    w.beginObject(4);
    w.writeField("src_addr"); write_addr(w, obj.src_addr_);;
    w.writeField("dst_addr"); write_addr(w, obj.dst_addr_);;
    w.writeField("distance"); w.writeFloat64(obj.distance_);;
    w.writeField("duration"); w.writeFloat64(obj.duration_);;
    w.endObject();
}

export inline specodec::SpecCodec<Mix15> Mix15Codec = {
    .encode = [](specodec::SpecWriter& w, const Mix15& obj) { write_mix15(w, obj); },
    .decode = [](specodec::SpecReader& r) -> Mix15 {
        Addr fld_src_addr = {};
        Addr fld_dst_addr = {};
        double fld_distance = 0.0;
        double fld_duration = 0.0;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "src_addr") { fld_src_addr = AddrCodec.decode(r); }
            else if (field_name == "dst_addr") { fld_dst_addr = AddrCodec.decode(r); }
            else if (field_name == "distance") { fld_distance = r.readFloat64(); }
            else if (field_name == "duration") { fld_duration = r.readFloat64(); }
            else { r.skip(); }
        }
        r.endObject();
        return Mix15{fld_src_addr, fld_dst_addr, fld_distance, fld_duration};
    }
};

