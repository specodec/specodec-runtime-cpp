        std::string fld_key = "";
        std::optional<std::int32_t> fld_intValue;
        std::optional<std::string> fld_strValue;
        std::optional<bool> fld_boolValue;
        std::optional<double> fld_floatValue;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "key") { fld_key = r.readString(); }
            else if (field_name == "intValue") { fld_intValue = std::optional<std::int32_t>{r.readInt32()}; }
            else if (field_name == "strValue") { fld_strValue = std::optional<std::string>{r.readString()}; }
            else if (field_name == "boolValue") { fld_boolValue = std::optional<bool>{r.readBool()}; }
            else if (field_name == "floatValue") { fld_floatValue = std::optional<double>{r.readFloat64()}; }
            else { r.skip(); }
        }
        r.endObject();
        return ConfigEntry{fld_key, fld_intValue, fld_strValue, fld_boolValue, fld_floatValue};
    }
};

} // namespace alltypes