    .decode = [](SpecReader& r) -> Ten05 {
        std::vector<std::uint8_t> _f1 = {};
        std::string _f2 = "";
        bool _f3 = false;
        std::int8_t _f4 = 0;
        std::int16_t _f5 = 0;
        std::int32_t _f6 = 0;
        std::int64_t _f7 = 0LL;
        std::uint8_t _f8 = 0u;
        std::uint16_t _f9 = 0u;
        std::uint32_t _f10 = 0u;
        r.beginObject();
        while (r.hasNextField()) {
            auto _fn = r.readFieldName();
            if (_fn == "f1") { _f1 = r.readBytes(); }
            else if (_fn == "f2") { _f2 = r.readString(); }
            else if (_fn == "f3") { _f3 = r.readBool(); }
            else if (_fn == "f4") { _f4 = static_cast<std::int8_t>(r.readInt32()); }
            else if (_fn == "f5") { _f5 = static_cast<std::int16_t>(r.readInt32()); }
            else if (_fn == "f6") { _f6 = r.readInt32(); }
            else if (_fn == "f7") { _f7 = r.readInt64(); }
            else if (_fn == "f8") { _f8 = static_cast<std::uint8_t>(r.readUint32()); }
            else if (_fn == "f9") { _f9 = static_cast<std::uint16_t>(r.readUint32()); }
            else if (_fn == "f10") { _f10 = r.readUint32(); }
            else { r.skip(); }
        }
        r.endObject();
        return Ten05{_f1, _f2, _f3, _f4, _f5, _f6, _f7, _f8, _f9, _f10};
    }
};

