export struct DeepNest6 {
    std::vector<IdVal> items_;
    std::optional<Addr> addr_;
    Coord coord_;
};

export inline void write_deep_nest6(specodec::SpecWriter& w, const DeepNest6& obj) {
    int field_count = 2;
    if (obj.addr_.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("items"); 
        w.beginArray(obj.items_.size());
        for (const auto& elem : obj.items_) { w.nextElement(); write_id_val(w, elem); }
        w.endArray();
    if (obj.addr_.has_value()) { w.writeField("addr"); write_addr(w, obj.addr_.value());; }
    w.writeField("coord"); write_coord(w, obj.coord_);;
    w.endObject();
}

export inline specodec::SpecCodec<DeepNest6> DeepNest6Codec = {
    .encode = [](specodec::SpecWriter& w, const DeepNest6& obj) { write_deep_nest6(w, obj); },
    .decode = [](specodec::SpecReader& r) -> DeepNest6 {
        std::vector<IdVal> fld_items = {};
        std::optional<Addr> fld_addr;
        Coord fld_coord = {};
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "items") { fld_items = [&]() {
    std::vector<IdVal> result;
    r.beginArray();
    while (r.hasNextElement()) { result.push_back(IdValCodec.decode(r)); }
    r.endArray();
    return result;
}(); }
            else if (field_name == "addr") { fld_addr = std::optional<Addr>{(r.isNull() ? (r.readNull(), std::optional<Addr>{std::nullopt}) : std::optional<Addr>{AddrCodec.decode(r)})}; }
            else if (field_name == "coord") { fld_coord = CoordCodec.decode(r); }
            else { r.skip(); }
        }
        r.endObject();
        return DeepNest6{fld_items, fld_addr, fld_coord};
    }
};

export struct DeepNest7 {
    Addr a_;
    Addr b_;
    Addr c_;
};

export inline void write_deep_nest7(specodec::SpecWriter& w, const DeepNest7& obj) {
    w.beginObject(3);
    w.writeField("a"); write_addr(w, obj.a_);;
    w.writeField("b"); write_addr(w, obj.b_);;
    w.writeField("c"); write_addr(w, obj.c_);;
    w.endObject();
}

export inline specodec::SpecCodec<DeepNest7> DeepNest7Codec = {
    .encode = [](specodec::SpecWriter& w, const DeepNest7& obj) { write_deep_nest7(w, obj); },
    .decode = [](specodec::SpecReader& r) -> DeepNest7 {
        Addr fld_a = {};
        Addr fld_b = {};
        Addr fld_c = {};
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "a") { fld_a = AddrCodec.decode(r); }
            else if (field_name == "b") { fld_b = AddrCodec.decode(r); }
            else if (field_name == "c") { fld_c = AddrCodec.decode(r); }
            else { r.skip(); }
        }
        r.endObject();
        return DeepNest7{fld_a, fld_b, fld_c};
    }
};

export struct TimestampEntry {
    std::int64_t ts_;
    std::string event_;
    std::optional<std::vector<std::uint8_t>> payload_;
};

export inline void write_timestamp_entry(specodec::SpecWriter& w, const TimestampEntry& obj) {
    int field_count = 2;
    if (obj.payload_.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("ts"); w.writeInt64(obj.ts_);;
    w.writeField("event"); w.writeString(obj.event_);;
    if (obj.payload_.has_value()) { w.writeField("payload"); w.writeBytes(obj.payload_.value());; }
    w.endObject();
}

export inline specodec::SpecCodec<TimestampEntry> TimestampEntryCodec = {
    .encode = [](specodec::SpecWriter& w, const TimestampEntry& obj) { write_timestamp_entry(w, obj); },
    .decode = [](specodec::SpecReader& r) -> TimestampEntry {
        std::int64_t fld_ts = 0LL;
        std::string fld_event = "";
        std::optional<std::vector<std::uint8_t>> fld_payload;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "ts") { fld_ts = r.readInt64(); }
            else if (field_name == "event") { fld_event = r.readString(); }
            else if (field_name == "payload") { fld_payload = std::optional<std::vector<std::uint8_t>>{r.readBytes()}; }
            else { r.skip(); }
        }
        r.endObject();
        return TimestampEntry{fld_ts, fld_event, fld_payload};
    }
};

export struct ConfigEntry {
    std::string key_;
    std::optional<std::int32_t> int_value_;
    std::optional<std::string> str_value_;
    std::optional<bool> bool_value_;
    std::optional<double> float_value_;
};

export inline void write_config_entry(specodec::SpecWriter& w, const ConfigEntry& obj) {
    int field_count = 1;
    if (obj.int_value_.has_value()) field_count++;
    if (obj.str_value_.has_value()) field_count++;
    if (obj.bool_value_.has_value()) field_count++;
    if (obj.float_value_.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("key"); w.writeString(obj.key_);;
    if (obj.int_value_.has_value()) { w.writeField("intValue"); w.writeInt32(obj.int_value_.value());; }
    if (obj.str_value_.has_value()) { w.writeField("strValue"); w.writeString(obj.str_value_.value());; }
    if (obj.bool_value_.has_value()) { w.writeField("boolValue"); w.writeBool(obj.bool_value_.value());; }
    if (obj.float_value_.has_value()) { w.writeField("floatValue"); w.writeFloat64(obj.float_value_.value());; }
    w.endObject();
}

export inline specodec::SpecCodec<ConfigEntry> ConfigEntryCodec = {
    .encode = [](specodec::SpecWriter& w, const ConfigEntry& obj) { write_config_entry(w, obj); },
    .decode = [](specodec::SpecReader& r) -> ConfigEntry {
        std::string fld_key = "";
        std::optional<std::int32_t> fld_int_value;
        std::optional<std::string> fld_str_value;
        std::optional<bool> fld_bool_value;
        std::optional<double> fld_float_value;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "key") { fld_key = r.readString(); }
            else if (field_name == "intValue") { fld_int_value = std::optional<std::int32_t>{r.readInt32()}; }
            else if (field_name == "strValue") { fld_str_value = std::optional<std::string>{r.readString()}; }
            else if (field_name == "boolValue") { fld_bool_value = std::optional<bool>{r.readBool()}; }
            else if (field_name == "floatValue") { fld_float_value = std::optional<double>{r.readFloat64()}; }
            else { r.skip(); }
        }
        r.endObject();
        return ConfigEntry{fld_key, fld_int_value, fld_str_value, fld_bool_value, fld_float_value};
    }
};

} // namespace all_types_extra