};

export inline void write_rec_list(specodec::SpecWriter& w, const RecList& obj) {
    int field_count = 1;
    if (obj.next != nullptr) field_count++;
    w.beginObject(field_count);
    w.writeField("value"); w.writeInt32(obj.value);;
    if (obj.next != nullptr) { w.writeField("next"); write_rec_list(w, *obj.next);; }
    w.endObject();
}

export inline specodec::SpecCodec<RecList> RecListCodec = {
    .encode = [](specodec::SpecWriter& w, const RecList& obj) { write_rec_list(w, obj); },
    .decode = [](specodec::SpecReader& r) -> RecList {
        std::int32_t fld_value = 0;
        std::shared_ptr<RecList> fld_next;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "value") { fld_value = r.readInt32(); }
            else if (field_name == "next") { auto opt = (r.isNull() ? (r.readNull(), std::optional<RecList>{std::nullopt}) : std::optional<RecList>{RecListCodec.decode(r)}); fld_next = opt ? std::make_shared<RecList>(*opt) : nullptr; }
            else { r.skip(); }
        }
        r.endObject();
        return RecList{fld_value, fld_next};
    }
};

