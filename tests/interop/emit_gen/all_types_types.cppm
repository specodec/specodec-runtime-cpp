    .encode = [](specodec::SpecWriter& w, const EdgeNullable& obj) { write_edge_nullable(w, obj); },
    .decode = [](specodec::SpecReader& r) -> EdgeNullable {
        std::optional<std::string> fld_a;
        std::optional<std::int32_t> fld_b;
        std::optional<Inner> fld_c;
        std::optional<std::vector<std::string>> fld_d;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "a") { fld_a = std::optional<std::string>{r.readString()}; }
            else if (field_name == "b") { fld_b = std::optional<std::int32_t>{r.readInt32()}; }
            else if (field_name == "c") { fld_c = std::optional<Inner>{(r.isNull() ? (r.readNull(), std::optional<Inner>{std::nullopt}) : std::optional<Inner>{InnerCodec.decode(r)})}; }
            else if (field_name == "d") { fld_d = std::optional<std::vector<std::string>>{[&]() {
    std::vector<std::string> result;
    r.beginArray();
    while (r.hasNextElement()) { result.push_back(r.readString()); }
    r.endArray();
    return result;
}()}; }
            else { r.skip(); }
        }
        r.endObject();
        return EdgeNullable{fld_a, fld_b, fld_c, fld_d};
    }
};

