export struct EdgeEmpty {};

export inline void write_edge_empty(specodec::SpecWriter& w, const EdgeEmpty& obj) {
    w.beginObject(0);
    w.endObject();
}

export inline specodec::SpecCodec<EdgeEmpty> EdgeEmptyCodec = {
    .encode = [](specodec::SpecWriter& w, const EdgeEmpty& obj) { write_edge_empty(w, obj); },
    .decode = [](specodec::SpecReader& r) -> EdgeEmpty {
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
        }
        r.endObject();
        return EdgeEmpty{};
    }
};

export struct EdgeOneOpt {
    std::optional<std::string> maybe;
};

export inline void write_edge_one_opt(specodec::SpecWriter& w, const EdgeOneOpt& obj) {
    int field_count = 0;
    if (obj.maybe.has_value()) field_count++;
    w.beginObject(field_count);
    if (obj.maybe.has_value()) { w.writeField("maybe"); w.writeString(obj.maybe.value());; }
    w.endObject();
}

export inline specodec::SpecCodec<EdgeOneOpt> EdgeOneOptCodec = {
    .encode = [](specodec::SpecWriter& w, const EdgeOneOpt& obj) { write_edge_one_opt(w, obj); },
    .decode = [](specodec::SpecReader& r) -> EdgeOneOpt {
        std::optional<std::string> fld_maybe;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "maybe") { fld_maybe = std::optional<std::string>{r.readString()}; }
            else { r.skip(); }
        }
        r.endObject();
        return EdgeOneOpt{fld_maybe};
    }
};

