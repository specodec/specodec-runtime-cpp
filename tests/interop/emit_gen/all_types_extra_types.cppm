        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "labels") { fld_labels = [&]() {
    std::vector<Label> result;
    r.beginArray();
    while (r.hasNextElement()) { result.push_back(LabelCodec.decode(r)); }
    r.endArray();
    return result;
}(); }
            else if (field_name == "money") { fld_money = MoneyCodec.decode(r); }
            else if (field_name == "name") { fld_name = r.readString(); }
