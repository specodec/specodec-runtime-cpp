    std::string c_;
    bool d_;
    std::vector<std::uint8_t> e_;
    Inner nested_;
};

export inline void write_mix13(specodec::SpecWriter& w, const Mix13& obj) {
    w.beginObject(6);
    w.writeField("a"); w.writeInt32(obj.a_);;
    w.writeField("b"); w.writeFloat64(obj.b_);;
    w.writeField("c"); w.writeString(obj.c_);;
    w.writeField("d"); w.writeBool(obj.d_);;
    w.writeField("e"); w.writeBytes(obj.e_);;
    w.writeField("nested"); write_inner(w, obj.nested_);;
    w.endObject();
}

export inline specodec::SpecCodec<Mix13> Mix13Codec = {
    .encode = [](specodec::SpecWriter& w, const Mix13& obj) { write_mix13(w, obj); },
    .decode = [](specodec::SpecReader& r) -> Mix13 {
        std::int32_t fld_a = 0;
        double fld_b = 0.0;
        std::string fld_c = "";
        bool fld_d = false;
        std::vector<std::uint8_t> fld_e = {};
        Inner fld_nested = {};
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "a") { fld_a = r.readInt32(); }
            else if (field_name == "b") { fld_b = r.readFloat64(); }
            else if (field_name == "c") { fld_c = r.readString(); }
            else if (field_name == "d") { fld_d = r.readBool(); }
            else if (field_name == "e") { fld_e = r.readBytes(); }
            else if (field_name == "nested") { fld_nested = InnerCodec.decode(r); }
            else { r.skip(); }
        }
        r.endObject();
        return Mix13{fld_a, fld_b, fld_c, fld_d, fld_e, fld_nested};
    }
};

