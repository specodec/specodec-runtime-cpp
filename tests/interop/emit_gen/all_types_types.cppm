};

export inline void write_config_entry(specodec::SpecWriter& w, const ConfigEntry& obj) {
    int field_count = 1;
    if (obj.intValue.has_value()) field_count++;
    if (obj.strValue.has_value()) field_count++;
    if (obj.boolValue.has_value()) field_count++;
    if (obj.floatValue.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("key"); w.writeString(obj.key);;
    if (obj.intValue.has_value()) { w.writeField("intValue"); w.writeInt32(obj.intValue.value());; }
    if (obj.strValue.has_value()) { w.writeField("strValue"); w.writeString(obj.strValue.value());; }
    if (obj.boolValue.has_value()) { w.writeField("boolValue"); w.writeBool(obj.boolValue.value());; }
    if (obj.floatValue.has_value()) { w.writeField("floatValue"); w.writeFloat64(obj.floatValue.value());; }
    w.endObject();
}

