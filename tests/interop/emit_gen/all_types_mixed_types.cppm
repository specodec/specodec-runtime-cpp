            auto field_name = r.readFieldName();
            if (field_name == "name") { fld_name = r.readString(); }
            else if (field_name == "values") { fld_values = [&]() {
    std::vector<double> result;
    r.beginArray();
    while (r.hasNextElement()) { result.push_back(r.readFloat64()); }
    r.endArray();
    return result;
}(); }
            else if (field_name == "nested") { fld_nested = std::optional<Inner>{(r.isNull() ? (r.readNull(), std::optional<Inner>{std::nullopt}) : std::optional<Inner>{InnerCodec.decode(r)})}; }
            else if (field_name == "flag") { fld_flag = std::optional<bool>{r.readBool()}; }
            else { r.skip(); }
        }
        r.endObject();
        return Mix11{fld_name, fld_values, fld_nested, fld_flag};
    }
};

export struct Mix12 {
    std::string header_;
    std::vector<IdVal> entries_;
    std::optional<std::string> footer_;
};

export inline void write_mix12(specodec::SpecWriter& w, const Mix12& obj) {
    int field_count = 2;
    if (obj.footer_.has_value()) field_count++;
    w.beginObject(field_count);
    w.writeField("header"); w.writeString(obj.header_);;
    w.writeField("entries"); 
        w.beginArray(obj.entries_.size());
        for (const auto& elem : obj.entries_) { w.nextElement(); write_id_val(w, elem); }
        w.endArray();
    if (obj.footer_.has_value()) { w.writeField("footer"); w.writeString(obj.footer_.value());; }
    w.endObject();
}

export inline specodec::SpecCodec<Mix12> Mix12Codec = {
    .encode = [](specodec::SpecWriter& w, const Mix12& obj) { write_mix12(w, obj); },
    .decode = [](specodec::SpecReader& r) -> Mix12 {
        std::string fld_header = "";
        std::vector<IdVal> fld_entries = {};
        std::optional<std::string> fld_footer;
        r.beginObject();
        while (r.hasNextField()) {
            auto field_name = r.readFieldName();
            if (field_name == "header") { fld_header = r.readString(); }
            else if (field_name == "entries") { fld_entries = [&]() {
    std::vector<IdVal> result;
    r.beginArray();
    while (r.hasNextElement()) { result.push_back(IdValCodec.decode(r)); }
    r.endArray();
    return result;
}(); }
            else if (field_name == "footer") { fld_footer = std::optional<std::string>{r.readString()}; }
            else { r.skip(); }
        }
        r.endObject();
        return Mix12{fld_header, fld_entries, fld_footer};
    }
};

export struct Mix13 {
    std::int32_t a_;
